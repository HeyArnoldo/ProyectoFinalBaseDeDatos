{
  "name": "restaurant-polyglot-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Restaurant polyglot platform monorepo",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm --filter @app/api run test && pnpm --filter @app/web run test",
    "test:docker": "pnpm --filter @app/api run test:docker",
    "test:e2e": "pnpm --filter @app/web run test:e2e",
    "test:all": "pnpm test && pnpm test:e2e"
  },
  "devDependencies": {
    "typescript": "~5.9.3"
  }
}
